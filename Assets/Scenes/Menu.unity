  progressText: {fileID: 1207178573}
  nextButton: {fileID: 973333369}
  nextButtonText: {fileID: 105468219}
  steps:
  - message: 'Bienvenue sur Gnoms Rush ! '
    highlightTarget: {fileID: 1789551053}
    fontSize: 130
  - message: Ici, tu peux acheter des objets de soutien comme des fioles de glace
      ou de la dynamite pour t'aider pendant les combats les plus rudes.
    highlightTarget: {fileID: 1907315657}
    fontSize: 77.6
  - message: "Va ici pour retoucher ton setup de jeu que ce soit son ou qualit\xE9
      graphique."
    highlightTarget: {fileID: 1344883497}
    fontSize: 90
  - message: "Regarde ici pour suivre tes qu\xEAtes obtenir des r\xE9compenses et
      voir ta progression actuelle !"
    highlightTarget: {fileID: 1093211152}
    fontSize: 88
  - message: "Clique ici pour choisir ton prochain champ de bataille. Chaque niveau
      te r\xE9serve de nouveaux d\xE9fis !"
    highlightTarget: {fileID: 2007980302}
    fontSize: 85
  - message: "Tu sais tout ! D\xE9ploie tes troupes, place tes tours strat\xE9giquement
      et ne laisse passer aucun ennemi. Bonne chance !"
    highlightTarget: {fileID: 1789551053}
    fontSize: 79.6
  stepSound: {fileID: 8300000, guid: a251d46874bfc064cae7290143008d6b, type: 3}
  volume: 1
  cameraMovementScript: {fileID: 0}
